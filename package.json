{
  "name": "vcti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web --bun astro dev",
    "dev:web": "bun run --cwd apps/web --bun astro dev",
    "dev:miniapp": "bun run --cwd apps/miniapp --bun taro build --type h5 --watch",
    "build": "bun run --cwd apps/web --bun astro build",
    "build:web": "bun run --cwd apps/web --bun astro build",
    "build:miniapp": "bun run --cwd apps/miniapp --bun taro build --type weapp",
    "preview": "bun run --cwd apps/web --bun astro preview",
    "check": "bun run --cwd apps/web --bun astro check",
    "check:web": "bun run --cwd apps/web --bun astro check",
    "check:miniapp": "bun run --cwd apps/miniapp --bun taro build --type weapp",
    "lint": "bun run biome check .",
    "format": "bun run biome format --write .",
    "validate": "bun run check && bun run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13"
  },
  "trustedDependencies": [
    "rustywind"
  ]
}
