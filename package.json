{
  "name": "vcti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "build:web": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "check": "bun run --cwd apps/web check",
    "lint": "biome check .",
    "format": "biome format --write .",
    "validate": "bun run check && bun run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12"
  },
  "trustedDependencies": [
    "rustywind"
  ]
}
