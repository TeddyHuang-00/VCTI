---
import VctiApp from "@/components/VctiApp";
import BaseLayout from "@/layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout
  title="VCTI | Vibe-Coder Type Indicator"
  description="面向 GitHub Pages 与未来多端迁移的 VCTI 问卷应用。"
  ogImagePath="/og/vcti.png"
>
  <main class="min-h-screen">
    <section class="overflow-hidden relative hero-grid">
      <VctiApp client:only="react" basePath={basePath} />
    </section>
  </main>
</BaseLayout>
