---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImagePath?: string;
}

const {
  title = "VCTI",
  description = "Vibe-Coder Type Indicator — 破译你的编程人格暗码。",
  ogImagePath = "/og/vcti.png",
} = Astro.props;
const basePath = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL("https://example.github.io");
const siteWithBase = new URL(basePath, site);
const normalizedOgImagePath = ogImagePath.startsWith("/") ? ogImagePath.slice(1) : ogImagePath;
const canonicalUrl = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(normalizedOgImagePath, siteWithBase).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href={`${basePath}favicon.ico`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${basePath}favicon-16x16.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${basePath}favicon-32x32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${basePath}apple-touch-icon.png`} />
    <link rel="manifest" href={`${basePath}site.webmanifest`} />
    <link rel="preload" href={`${basePath}fonts/LXGWNeoXiHei-Regular.ttf`} as="font" type="font/ttf" crossorigin />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <div class="flex-1">
      <slot />
    </div>
    <footer class="py-10 px-4 text-center text-[13px] tracking-[0.14px] text-warmgray">
      <p>
        本测试仅供娱乐，别太当真。创意来自本 MDRC 人，但全部代码均为 Vibe Coding 产物🤪。
      </p>
      <p class="mt-2">
        <a href="https://github.com/TeddyHuang-00/VCTI" class="underline transition-colors hover:text-black underline-offset-2">GitHub</a>
        <span class="mx-2">·</span>
        MIT License
      </p>
    </footer>
  </body>
</html>
